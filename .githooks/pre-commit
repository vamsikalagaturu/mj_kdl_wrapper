#!/usr/bin/env bash
# Pre-commit hook: enforce clang-format on staged C++ files.
# Install: git config core.hooksPath .githooks

set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|hpp|cc|h)$' || true)

if [ -z "$staged" ]; then
    exit 0
fi

failed=()
for f in $staged; do
    if ! clang-format --dry-run --Werror "$f" 2>/dev/null; then
        failed+=("$f")
    fi
done

if [ ${#failed[@]} -gt 0 ]; then
    echo "clang-format: the following files need formatting:"
    for f in "${failed[@]}"; do
        echo "  $f"
    done
    echo "Run: clang-format -i ${failed[*]}"
    exit 1
fi
